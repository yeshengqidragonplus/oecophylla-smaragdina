{
  "name": "oecophylla-smaragdina",
  "displayName": "Oecophylla smaragdina",
  "description": "一个用于小型内网简单通信的 VS Code 插件",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:OSChatView",
    "onCommand:myChat.openSettings"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "OSChatContainer",
          "title": "Oecophy Smaragdina Chat",
          "icon": "media/robot.svg"
        }
      ]
    },
    "views": {
      "OSChatContainer": [
        {
          "type": "webview",
          "id": "OSChatView",
          "name": "OS Chat",
          "icon": "media/robot.svg",
          "contextualTitle": "OS Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "myChat.openSettings",
        "title": "设置",
        "icon": "$(gear)"
      },
      {
        "command": "myChat.newChat",
        "title": "新建会话",
        "icon": "$(edit)"
      },
      {
        "command": "myChat.startNetwork",
        "title": "启动网络服务",
        "icon": "$(play)"
      },
      {
        "command": "myChat.stopNetwork",
        "title": "停止网络服务",
        "icon": "$(debug-stop)"
      },
      {
        "command": "myChat.editPeers",
        "title": "编辑聊天对象",
        "icon": "$(edit)"
      },
      {
        "command": "myChat.openPeersFile",
        "title": "打开 peers.json 配置文件",
        "icon": "$(file-code)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "myChat.newChat",
          "when": "view == OSChatView",
          "group": "navigation"
        },
        {
          "command": "myChat.startNetwork",
          "when": "view == OSChatView",
          "group": "navigation"
        },
        {
          "command": "myChat.openSettings",
          "when": "view == OSChatView",
          "group": "navigation"
        },
        {
          "command": "myChat.editPeers",
          "when": "view == OSChatView",
          "group": "navigation"
        },
        {
          "command": "myChat.openPeersFile",
          "when": "view == OSChatView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "OS Chat",
      "properties": {
        "oschat.port": {
          "type": "number",
          "default": 8080,
          "description": "网络服务监听端口"
        },
        "oschat.nickname": {
          "type": "string",
          "default": "",
          "description": "你的昵称（可选）"
        },
        "oschat.autoConnect": {
          "type": "boolean",
          "default": false,
          "description": "启动时自动启动网络服务"
        },
        "oschat.peersFilePath": {
          "type": "string",
          "default": "",
          "description": "聊天对象配置文件 peers.json 的保存文件夹路径。留空则保存在扩展全局存储目录。peers.json 文件格式示例：[{\"ip\": \"192.168.1.100\", \"port\": 8080, \"nickname\": \"用户A\", \"hostname\": \"PC-A\"}]"
        },
        "oschat.downloadPath": {
          "type": "string",
          "default": "",
          "description": "接收文件保存的文件夹路径，留空使用默认位置"
        },
        "oschat.theme": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "light",
            "dark"
          ],
          "enumDescriptions": [
            "跟随 VS Code 主题",
            "浅色主题",
            "深色主题"
          ],
          "description": "聊天界面主题"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.92.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "kcpjs": "^1.0.12"
  }
}
